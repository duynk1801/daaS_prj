# ─── App ─────────────────────────────────────────────────────────────────────
APP_NAME=Drone Booking Service
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=development

# Server
HOST=127.0.0.1
PORT=8000

# CORS — comma-separated list of allowed origins (no wildcard!)
CORS_ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=drone_user
# SECURITY: Set a strong password — never use default in production
DB_PASSWORD=your_strong_db_password_here
DB_NAME=drone_booking
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# SECURITY: Set a strong password — never use default in production
REDIS_PASSWORD=your_strong_redis_password_here
REDIS_SLOT_LOCK_TTL_SECONDS=300

# ─── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=drone_user
# SECURITY: Set a strong password — never use default in production
RABBITMQ_PASSWORD=your_strong_rabbitmq_password_here
RABBITMQ_VHOST=/
RABBITMQ_BOOKING_EXCHANGE=booking.events

# ─── JWT ──────────────────────────────────────────────────────────────────────
# SECURITY CRITICAL: Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# NEVER use a hardcoded string or leave this blank in production!
JWT_SECRET_KEY=your_256_bit_secret_key_here_generate_with_secrets_token_hex_32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Booking Business Rules ───────────────────────────────────────────────────
BOOKING_MIN_HOUR=6
BOOKING_MAX_HOUR=18
BOOKING_EXPIRY_MINUTES=30

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
